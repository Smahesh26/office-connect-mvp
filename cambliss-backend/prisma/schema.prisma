generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RoleName {
  SUPER_ADMIN
  ADMIN
  PROJECT_MANAGER
  EMPLOYEE
  CLIENT
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  SUSPENDED
}

model Organization {
  id            String         @id @default(cuid())
  name          String
  isActive      Boolean        @default(true)
  legalName     String?
  panNumber     String?
  businessType  String?
  supportEmail  String?
  supportPhone  String?
  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  pincode       String?
  country       String?
  settlementAccountHolderName String?
  settlementAccountNumber     String?
  settlementIFSC              String?
  defaultInvoicePdfTemplate   String         @default("classic")
  
  // Multi-currency support
  baseCurrency  String         @default("INR")
  supportedCurrencies String[]  @default(["INR", "USD", "EUR", "GBP"])
  enableMultiCurrency Boolean   @default(true)

  users         User[]
  memberships   OrganizationUser[]
  subscriptions Subscription[]
  organizationModules OrganizationModule[]
  projects      Project[]
  files         File[]
  contacts      Contact[]
  accountingPeriods AccountingPeriod[]
  stores        Store[] @relation("StoreOrganization")
  posTerminals  POSTerminal[]
  posOrders     POSOrder[]
  invoices      Invoice[]
  gstConfig     GSTConfig?
  currencyRates CurrencyExchangeRate[]
  regionalTaxes RegionalTax[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model User {
  id               String             @id @default(cuid())
  email            String             @unique
  firstName        String?
  lastName         String?
  passwordHash     String

  // Platform-level user (SUPER_ADMIN)
  isPlatformUser   Boolean            @default(false)

  // Optional for SUPER_ADMIN
  organizationId   String?
  organization     Organization?      @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  memberships      OrganizationUser[]
  projectMembers   ProjectMember[]
  assignedTasks    Task[]
  uploadedFiles    File[]
  employees        Employee[]
  leads            Lead[] @relation("LeadAssignee")
  activities       Activity[]
  dealStageHistories   DealStageHistory[]
  ownedStores      Store[] @relation("StoreOwner")
  storeMemberships StoreMember[]

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([organizationId])
}

model Role {
  id          String       @id @default(cuid())
  name        RoleName     @unique

  memberships OrganizationUser[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model OrganizationUser {
  id             String       @id @default(cuid())

  organizationId String
  userId         String
  roleId         String

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([roleId])
}

model Plan {
  id            String         @id @default(cuid())
  name          String         @unique
  description   String?
  features      String[]       @default([])

  price         Decimal        @db.Decimal(10, 2)
  currency      String         @default("USD")

  interval      String         // MONTHLY / YEARLY

  userLimit     Int            @default(5)
  storageLimit  Int            @default(5) // GB

  isActive      Boolean        @default(true)

  subscriptions Subscription[]
  planModules   PlanModule[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Subscription {
  id                 String             @id @default(cuid())

  organizationId     String
  planId             String

  status             SubscriptionStatus @default(TRIALING)

  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  cancelAtPeriodEnd  Boolean            @default(false)

  organization       Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan               Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  payments           Payment[]

  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([organizationId])
  @@index([planId])
}

model Payment {
  id                 String       @id @default(cuid())

  subscriptionId     String
  amount             Decimal      @db.Decimal(10, 2)
  currency           String       @default("USD")

  provider           String?      // Razorpay, Stripe
  externalPaymentId  String?      @unique

  paidAt             DateTime     @default(now())

  subscription       Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([subscriptionId])
}
model Project {
  id             String    @id @default(cuid())
  name           String
  description    String?
  status         String    @default("ACTIVE")

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  tasks          Task[]
  members        ProjectMember[]
  files          File[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([organizationId])
}

model ProjectMember {
  id        String   @id @default(cuid())
  projectId String
  userId    String

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([projectId, userId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      String   @default("TODO") // TODO, IN_PROGRESS, DONE
  priority    String   @default("MEDIUM")

  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignedTo  String?
  assignee    User?    @relation(fields: [assignedTo], references: [id])

  dueDate     DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}
model File {
  id             String   @id @default(cuid())
  fileName       String
  filePath       String
  fileSize       Int      // in bytes

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  uploadedBy     String
  uploader       User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([projectId])
}
model Contact {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  transactions    Transaction[]
  purchaseOrders  PurchaseOrder[]
  leads           Lead[]
  deals           Deal[]
  orders          Order[] @relation("OrderContact")
  carts           Cart[]  @relation("CartContact")
  posOrders       POSOrder[]
  invoices        Invoice[]

  type            ContactType
  firstName       String?
  lastName        String?
  companyName     String?
  email           String?
  phone           String?
  gstNumber       String?
  panNumber       String?
  state           String?
  stateCode       String?

  billingAddress  String?
  shippingAddress String?

  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
}

enum ContactType {
  CUSTOMER
  VENDOR
  PARTNER
}

enum StoreMemberRole {
  OWNER
  MANAGER
  STAFF
  VIEWER
}

model Department {
  id             String   @id @default(cuid())
  organizationId String
  name           String

  employees      Employee[]

  @@unique([organizationId, name])
}

model Location {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?

  employees      Employee[]

  @@unique([organizationId, name])
}

model Designation {
  id             String   @id @default(cuid())
  organizationId String
  title          String

  employees      Employee[]

  @@unique([organizationId, title])
}

model Team {
  id             String   @id @default(cuid())
  organizationId String
  name           String

  employees      Employee[]

  @@unique([organizationId, name])
}

model Employee {
  id             String   @id @default(cuid())
  organizationId String

  employeeCode   String

  userId         String?
  user           User?    @relation(fields: [userId], references: [id])

  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id])

  designationId  String?
  designation    Designation? @relation(fields: [designationId], references: [id])

  teamId         String?
  team           Team? @relation(fields: [teamId], references: [id])

  locationId     String?
  location       Location? @relation(fields: [locationId], references: [id])

  managerId      String?
  manager        Employee?   @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates   Employee[]  @relation("ManagerRelation")

  joinDate       DateTime
  confirmationDate DateTime?

  employmentType String
  workMode       String
  status         String @default("ACTIVE")

  salary         Decimal @db.Decimal(12,2)

  bankAccountNumber String?
  bankIFSC          String?
  taxId             String?

  dateOfBirth    DateTime?
  gender         String?
  phone          String?
  address        String?

  emergencyContactName  String?
  emergencyContactPhone String?

  attendances     Attendance[]
  leaveBalances   LeaveBalance[]
  leaveRequests   LeaveRequest[]
  salaryStructures SalaryStructure[]
  payslips        Payslip[]
  performanceReviews PerformanceReview[]
  documents       EmployeeDocument[]
  employeeShifts  EmployeeShift[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, employeeCode])
  @@index([organizationId])
}

model Shift {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  startTime      String
  endTime        String
  graceMinutes   Int @default(0)

  employees      EmployeeShift[]
}

model EmployeeShift {
  id         String   @id @default(cuid())
  employeeId String
  shiftId    String

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift      Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftId])
}

model Attendance {
  id             String   @id @default(cuid())
  organizationId String
  employeeId     String

  date           DateTime
  checkIn        DateTime?
  checkOut       DateTime?

  totalHours     Float?
  overtimeHours  Float?

  isLate         Boolean @default(false)
  status         String

  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([organizationId])
}

model LeavePolicy {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  annualQuota    Float
  carryForward   Boolean @default(false)

  leaveBalances  LeaveBalance[]
  leaveRequests  LeaveRequest[]

  @@unique([organizationId, name])
}

model LeaveBalance {
  id            String   @id @default(cuid())
  employeeId    String
  leavePolicyId String
  balance       Float

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leavePolicy   LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leavePolicyId])
}

model LeaveRequest {
  id            String   @id @default(cuid())
  employeeId    String
  leavePolicyId String

  startDate     DateTime
  endDate       DateTime
  reason        String?

  status        String @default("PENDING")
  approvedBy    String?

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leavePolicy   LeavePolicy @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
}

model SalaryComponent {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           String
  isPercentage   Boolean @default(false)
  value          Decimal @db.Decimal(8,2)

  salaryStructures SalaryStructure[]

  @@unique([organizationId, name])
}

model SalaryStructure {
  id            String   @id @default(cuid())
  employeeId    String
  componentId   String

  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  component     SalaryComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  @@unique([employeeId, componentId])
}

model Payslip {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int
  year        Int

  grossSalary Decimal @db.Decimal(12,2)
  netSalary   Decimal @db.Decimal(12,2)

  generatedAt DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([employeeId])
}

model PerformanceReview {
  id           String   @id @default(cuid())
  employeeId   String
  reviewerId   String

  rating       Int
  comments     String?

  reviewDate   DateTime @default(now())

  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([reviewerId])
}

model EmployeeDocument {
  id          String   @id @default(cuid())
  employeeId  String
  fileName    String
  filePath    String

  uploadedAt  DateTime @default(now())

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}
model Product {
  id              String   @id @default(cuid())
  organizationId  String

  name            String
  sku             String
  hsnCode         String?
  description     String?
  unitPrice       Decimal  @db.Decimal(12,2)
  costPrice       Decimal? @db.Decimal(12,2)

  taxRate         Decimal? @db.Decimal(5,2)

  isActive        Boolean  @default(true)

  stockItems      StockItem[]
  stockMovements  StockMovement[]
  purchaseItems   PurchaseItem[]
  gatePassItems   GatePassItem[]
  productListings ProductListing[]
  posOrderItems   POSOrderItem[]
  invoiceItems    InvoiceItem[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([organizationId, sku])
  @@index([organizationId])
}
model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  location       String?
  latitude       Float?
  longitude      Float?

  stockItems     StockItem[]
  stockMovements StockMovement[]
  gatePasses     GatePass[]

  @@unique([organizationId, name])
}

model GatePass {
  id             String         @id @default(cuid())
  organizationId String
  passNumber     String
  type           String         // INWARD | OUTWARD
  status         String         @default("OPEN") // OPEN | CLOSED | CANCELLED
  warehouseId    String
  vehicleNumber  String?
  driverName     String?
  referenceType  String?
  referenceId    String?
  notes          String?
  closedAt       DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  warehouse      Warehouse      @relation(fields: [warehouseId], references: [id])
  items          GatePassItem[]

  @@unique([organizationId, passNumber])
  @@index([organizationId])
  @@index([warehouseId])
  @@index([status])
}

model GatePassItem {
  id           String    @id @default(cuid())
  gatePassId   String
  productId    String
  quantity     Int

  gatePass     GatePass  @relation(fields: [gatePassId], references: [id], onDelete: Cascade)
  product      Product   @relation(fields: [productId], references: [id])

  @@index([gatePassId])
  @@index([productId])
}

model StockItem {
  id           String   @id @default(cuid())
  productId    String
  warehouseId  String

  quantity     Int

  product      Product  @relation(fields: [productId], references: [id])
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model StockMovement {
  id             String    @id @default(cuid())
  organizationId String

  productId      String
  warehouseId    String

  type           String    // PURCHASE, SALE, ADJUSTMENT, TRANSFER
  quantity       Int
  referenceId    String?
  notes          String?

  createdAt      DateTime  @default(now())

  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([productId])
  @@index([warehouseId])
}

model PurchaseOrder {
  id             String    @id @default(cuid())
  organizationId String

  vendorId       String
  vendor         Contact   @relation(fields: [vendorId], references: [id])

  status         String    @default("DRAFT") // DRAFT, APPROVED, RECEIVED
  totalAmount    Decimal   @db.Decimal(14,2)

  items          PurchaseItem[]

  createdAt      DateTime  @default(now())

  @@index([organizationId])
  @@index([vendorId])
}

model PurchaseItem {
  id           String        @id @default(cuid())
  purchaseId   String
  productId    String

  quantity     Int
  unitPrice    Decimal       @db.Decimal(12,2)
  
  gstRate      Decimal       @default(0) @db.Decimal(5,2)
  
  cgstAmount   Decimal       @default(0) @db.Decimal(12,2)
  sgstAmount   Decimal       @default(0) @db.Decimal(12,2)
  igstAmount   Decimal       @default(0) @db.Decimal(12,2)

  purchase     PurchaseOrder @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product      Product       @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

model Transaction {
  id              String   @id @default(cuid())
  organizationId  String

  type            TransactionType
  referenceNumber String?
  contactId       String?
  contact         Contact? @relation(fields: [contactId], references: [id])

  totalAmount     Decimal   @db.Decimal(14,2)
  status          String     // DRAFT, POSTED, PAID
  postedAt        DateTime?
  reversedAt      DateTime?
  reversalOfId    String?

  transactionDate DateTime

  journalEntries  JournalEntry[]
  paymentAllocations PaymentAllocation[]
  reversalOf      Transaction?  @relation("TransactionReversal", fields: [reversalOfId], references: [id])
  reversals       Transaction[] @relation("TransactionReversal")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([transactionDate])
  @@index([status])
}

enum TransactionType {
  SALE
  PURCHASE
  EXPENSE
  PAYMENT
  REFUND
}
model LedgerAccount {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  type           LedgerType
  code           String?
  parentId       String?
  isSystem       Boolean  @default(false)

  parent         LedgerAccount?  @relation("LedgerHierarchy", fields: [parentId], references: [id])
  children       LedgerAccount[] @relation("LedgerHierarchy")

  journalEntries JournalEntry[]

  @@index([organizationId])
  @@index([parentId])
  @@unique([organizationId, code])
}

enum LedgerType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model JournalEntry {
  id              String   @id @default(cuid())
  transactionId   String
  ledgerAccountId String

  debit           Decimal? @db.Decimal(14,2)
  credit          Decimal? @db.Decimal(14,2)

  transaction     Transaction @relation(fields: [transactionId], references: [id])
  ledgerAccount   LedgerAccount @relation(fields: [ledgerAccountId], references: [id])
}

model AccountingPeriod {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  startDate      DateTime
  endDate        DateTime
  isLocked       Boolean  @default(false)
  lockedAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([startDate, endDate])
}
model Module {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)

  planModules         PlanModule[]
  organizationModules OrganizationModule[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlanModule {
  id        String @id @default(cuid())
  planId    String
  moduleId  String

  plan      Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  module    Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleId])
}

model OrganizationModule {
  id             String @id @default(cuid())
  organizationId String
  moduleId       String
  isEnabled      Boolean @default(true)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  module         Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([organizationId, moduleId])
}
model Pipeline {
  id             String   @id @default(cuid())
  organizationId String
  name           String

  stages         Stage[]
  deals          Deal[]

  @@unique([organizationId, name])
}

// ============================================
// NO-COST CRM MODE (Internal-First)
// ============================================
// This CRM setup intentionally supports core operations without paid 3rd-party APIs.
// Existing model mapping:
// - Customer data: Contact
// - Leads: Lead
// - Opportunities/pipeline: Pipeline, Stage, Deal
// - Communication log: Activity
// - Stage audit history: DealStageHistory
//
// External providers (WhatsApp/SMS/Email gateways, telephony, etc.) are optional.
// Core CRM workflows must remain functional using only internal backend + database.

model Stage {
  id          String   @id @default(cuid())
  pipelineId  String
  name        String
  order       Int

  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]
  fromStageHistories DealStageHistory[] @relation("FromStage")
  toStageHistories   DealStageHistory[] @relation("ToStage")

  @@unique([pipelineId, order])
}

model Lead {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String?
  contact        Contact?  @relation(fields: [contactId], references: [id])

  firstName      String?
  email          String?
  phone          String?

  source         String?
  status         String   @default("NEW")
  score          Int      @default(0)
  assignedTo     String?
  assignee       User?    @relation("LeadAssignee", fields: [assignedTo], references: [id])

  isArchived     Boolean  @default(false)
  archivedAt     DateTime?
  activities     Activity[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([isArchived])
}

model Deal {
  id             String   @id @default(cuid())
  organizationId String
  contactId      String
  contact        Contact  @relation(fields: [contactId], references: [id])

  pipelineId     String
  stageId        String

  pipeline       Pipeline @relation(fields: [pipelineId], references: [id])
  stage          Stage    @relation(fields: [stageId], references: [id])

  value          Decimal  @db.Decimal(14,2)
  probability    Int      @default(0)
  expectedClose  DateTime?

  status         String   @default("OPEN") // OPEN, WON, LOST
  isProcessed    Boolean  @default(false)
  isArchived     Boolean  @default(false)
  archivedAt     DateTime?

  activities     Activity[]
  stageHistories DealStageHistory[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([isArchived])
}

model Activity {
  id         String   @id @default(cuid())
  dealId     String?
  leadId     String?
  createdBy  String?

  type       String   // CALL, EMAIL, MEETING
  note       String?
  dueDate    DateTime?
  completed  Boolean  @default(false)

  deal       Deal?      @relation(fields: [dealId], references: [id])
  lead       Lead?      @relation(fields: [leadId], references: [id])
  creator    User?      @relation(fields: [createdBy], references: [id])

  createdAt  DateTime @default(now())
}

model DealStageHistory {
  id           String   @id @default(cuid())
  dealId       String
  fromStageId  String?
  toStageId    String
  changedBy    String   // userId who made the change

  deal         Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  fromStage    Stage?   @relation("FromStage", fields: [fromStageId], references: [id])
  toStage      Stage    @relation("ToStage", fields: [toStageId], references: [id])
  user         User     @relation(fields: [changedBy], references: [id])

  changedAt    DateTime @default(now())

  @@index([dealId])
  @@index([changedBy])
}

// ============================================
// D2C / COMMERCE ENGINE
// ============================================

model Store {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization? @relation("StoreOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  ownerUserId    String?
  ownerUser      User?    @relation("StoreOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  name           String
  domain         String?  @unique
  description    String?
  businessTypes  String[] @default([])
  organizationType String?
  assortmentType String?
  onboardingPitch String?
  isActive       Boolean  @default(true)
  sellerTier     String   @default("new")
  isFeatured     Boolean  @default(false)
  tierUnlockedAt DateTime?
  paymentDisplayName      String?
  paymentUpiId            String?
  paymentBankAccountName  String?
  paymentBankAccountNo    String?
  paymentBankIfsc         String?
  paymentInstructions     String?

  categories     Category[]
  productListings ProductListing[]
  carts          Cart[]
  orders         Order[]
  members        StoreMember[]
  events         MarketplaceEvent[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([ownerUserId])
  @@index([sellerTier])
  @@index([isFeatured])
}

model StoreMember {
  id             String          @id @default(cuid())
  organizationId String
  storeId        String
  userId         String
  role           StoreMemberRole @default(STAFF)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  store          Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([storeId, userId])
  @@index([organizationId])
  @@index([storeId])
  @@index([userId])
}

model Category {
  id             String   @id @default(cuid())
  organizationId String

  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name           String
  description    String?
  image          String?

  parentId       String?
  parent         Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       Category[] @relation("CategoryHierarchy")

  productListings ProductListing[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, name, parentId])
  @@index([storeId])
  @@index([organizationId])
}

model ProductListing {
  id             String   @id @default(cuid())
  organizationId String

  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sellingPrice   Decimal  @db.Decimal(12,2)
  baseCurrency   String   @default("INR")
  // JSON format: { "USD": 100.50, "EUR": 95.25, "GBP": 88.00 }
  multiCurrencyPrices String? @default("{}")
  description    String?
  isActive       Boolean  @default(true)

  seoTitle       String?
  seoDescription String?
  images         String[]

  cartItems      CartItem[]
  orderItems     OrderItem[]
  events         MarketplaceEvent[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, productId])
  @@index([storeId])
  @@index([organizationId])
  @@index([productId])
}

model Order {
  id             String   @id @default(cuid())
  organizationId String

  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Restrict)

  customerId     String
  customer       Contact  @relation("OrderContact", fields: [customerId], references: [id], onDelete: Restrict)

  status         String   @default("PENDING")
  paymentStatus  String   @default("UNPAID")

  totalAmount    Decimal  @db.Decimal(14,2)
  currency       String   @default("INR")
  exchangeRate   Decimal  @default(1) @db.Decimal(10,6)
  baseCurrencyAmount Decimal @db.Decimal(14,2)  // Amount in base currency (INR)

  razorpayOrderId   String?
  razorpayPaymentId String?

  // Trust-based order flow
  sellerTrustTier String?
  inspectionRequired Boolean @default(false)
  holdReason     String?
  heldAt         DateTime?
  autoReleasedAt DateTime?

  // Fulfillment tracking
  packedAt       DateTime?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  
  trackingNumber String?
  courierPartner String?
  
  isRefunded     Boolean  @default(false)

  items          OrderItem[]
  returnRequests ReturnRequest[]
  invoice        Invoice?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([storeId])
  @@index([customerId])
  @@index([sellerTrustTier])
  @@index([inspectionRequired])
  @@index([currency])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productListingId String
  productListing   ProductListing @relation(fields: [productListingId], references: [id], onDelete: Restrict)

  quantity       Int
  unitPrice      Decimal  @db.Decimal(12,2)
  returnItems    ReturnItem[]

  createdAt      DateTime @default(now())

  @@index([orderId])
}

model ReturnRequest {
  id             String   @id @default(cuid())
  organizationId String

  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  status         String   @default("REQUESTED")
  reason         String?
  inspectedAt    DateTime?
  inspectionOutcome String?
  inspectionNotes String?
  rejectedAt     DateTime?
  rejectionReason String?
  approvedAt     DateTime?
  refundedAt     DateTime?
  refundAmount   Decimal? @db.Decimal(14,2)
  gatewayRefundId String?
  gatewayRefundStatus String?

  items          ReturnItem[]

  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([orderId])
}

model ReturnItem {
  id              String        @id @default(cuid())
  returnRequestId String
  orderItemId     String
  quantity        Int

  returnRequest   ReturnRequest @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  orderItem       OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  @@index([returnRequestId])
  @@index([orderItemId])
  @@unique([returnRequestId, orderItemId])
}

model POSTerminal {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  location       String?
  isActive       Boolean     @default(true)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  sessions       POSSession[]

  @@index([organizationId])
  @@unique([organizationId, name])
}

model POSSession {
  id             String      @id @default(cuid())
  terminalId     String
  openedBy       String
  openedAt       DateTime    @default(now())
  closedAt       DateTime?
  openingCash    Decimal     @db.Decimal(12,2)
  closingCash    Decimal?    @db.Decimal(12,2)

  terminal       POSTerminal @relation(fields: [terminalId], references: [id], onDelete: Restrict)
  orders         POSOrder[]

  @@index([terminalId])
  @@index([openedBy])
}

model POSOrder {
  id             String      @id @default(cuid())
  organizationId String
  sessionId      String
  customerId     String?
  totalAmount    Decimal     @db.Decimal(14,2)
  paymentMethod  String
  status         String      @default("COMPLETED")
  createdAt      DateTime    @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session        POSSession   @relation(fields: [sessionId], references: [id], onDelete: Restrict)
  customer       Contact?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items          POSOrderItem[]
  invoice        Invoice?

  @@index([organizationId])
  @@index([sessionId])
  @@index([customerId])
  @@index([createdAt])
}

model POSOrderItem {
  id         String    @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  price      Decimal   @db.Decimal(12,2)

  order      POSOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model GSTConfig {
  id             String   @id @default(cuid())
  organizationId String   @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  gstNumber      String
  legalName      String
  tradeName      String?
  stateCode      String   // Indian state code (e.g., "36" for Telangana)

  isComposition  Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model Invoice {
  id             String   @id @default(cuid())
  organizationId String

  invoiceNumber  String
  orderId        String?  @unique
  posOrderId     String?  @unique

  customerId     String?
  placeOfSupply  String?  // State code where supply is made
  
  subtotal       Decimal  @db.Decimal(14,2)
  cgstAmount     Decimal  @default(0) @db.Decimal(14,2)
  sgstAmount     Decimal  @default(0) @db.Decimal(14,2)
  igstAmount     Decimal  @default(0) @db.Decimal(14,2)
  totalAmount    Decimal  @db.Decimal(14,2)

  status         String   @default("ISSUED")
  issuedAt       DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  posOrder       POSOrder?    @relation(fields: [posOrderId], references: [id], onDelete: SetNull)
  customer       Contact?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  items          InvoiceItem[]
  ewayBills      EWayBill[]
  paymentAllocations PaymentAllocation[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([issuedAt])
}

model PaymentAllocation {
  id             String   @id @default(cuid())
  organizationId String
  transactionId  String
  invoiceId      String
  amount         Decimal  @db.Decimal(14,2)
  allocatedAt    DateTime @default(now())

  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  invoice        Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([transactionId, invoiceId])
  @@index([organizationId])
  @@index([invoiceId])
  @@index([transactionId])
}

model InvoiceItem {
  id         String   @id @default(cuid())
  invoiceId  String
  productId  String

  quantity   Int
  price      Decimal  @db.Decimal(12,2)
  
  gstRate    Decimal  @db.Decimal(5,2)  // Total GST rate (e.g., 18%)
  
  cgstRate   Decimal? @db.Decimal(5,2)
  sgstRate   Decimal? @db.Decimal(5,2)
  igstRate   Decimal? @db.Decimal(5,2)

  cgstAmount Decimal  @default(0) @db.Decimal(12,2)
  sgstAmount Decimal  @default(0) @db.Decimal(12,2)
  igstAmount Decimal  @default(0) @db.Decimal(12,2)

  invoice    Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([productId])
}

model EWayBill {
  id               String   @id @default(cuid())
  organizationId   String
  invoiceId        String

  transporterName  String?
  transporterGSTIN String?
  vehicleNumber    String?
  transportMode    String?  // ROAD, RAIL, AIR, SHIP

  distance         Int?     // Distance in kilometers

  status           String   @default("GENERATED") // GENERATED, CANCELLED

  generatedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([invoiceId])
  @@index([status])
}

model Cart {
  id             String   @id @default(cuid())
  organizationId String

  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerId     String
  customer       Contact  @relation("CartContact", fields: [customerId], references: [id], onDelete: Cascade)

  currency       String   @default("INR")
  exchangeRate   Decimal  @default(1) @db.Decimal(10,6)

  items          CartItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([storeId, customerId])
  @@index([organizationId])
  @@index([storeId])
  @@index([customerId])
}

model CartItem {
  id               String   @id @default(cuid())
  cartId           String
  cart             Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productListingId String
  productListing   ProductListing @relation(fields: [productListingId], references: [id], onDelete: Cascade)

  quantity         Int
  unitPrice        Decimal  @db.Decimal(12,2)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([cartId, productListingId])
  @@index([cartId])
}

// ============================================
// MULTI-CURRENCY & REGIONAL SUPPORT
// ============================================

model CurrencyExchangeRate {
  id             String   @id @default(cuid())
  organizationId String

  fromCurrency   String
  toCurrency     String
  rate           Decimal  @db.Decimal(10,6)
  effectiveDate  DateTime
  expiryDate     DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, fromCurrency, toCurrency, effectiveDate])
  @@index([organizationId])
  @@index([fromCurrency, toCurrency])
  @@index([effectiveDate])
}

model RegionalTax {
  id             String   @id @default(cuid())
  organizationId String

  region         String   // Country code (IN, US, GB, DE, etc.)
  country        String
  state          String?
  
  taxType        String   // VAT, GST, SALES_TAX, etc.
  taxRate        Decimal  @db.Decimal(5,2)
  
  isActive       Boolean  @default(true)
  effectiveDate  DateTime
  expiryDate     DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, region, state, taxType, effectiveDate])
  @@index([organizationId])
  @@index([region, state])
  @@index([effectiveDate])
}

// ============================================
// MARKETPLACE EVENTS & ANALYTICS
// ============================================

model MarketplaceEvent {
  id               String   @id @default(cuid())
  organizationId   String

  eventType        String
  eventData        String?

  customerId       String?
  storeId          String?
  productListingId String?

  store            Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  listing          ProductListing? @relation(fields: [productListingId], references: [id], onDelete: SetNull)

  createdAt        DateTime @default(now())

  @@index([organizationId])
  @@index([storeId])
  @@index([productListingId])
  @@index([eventType, createdAt])
}